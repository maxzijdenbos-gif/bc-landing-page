{
  "name": "giant",
  "version": "1.5.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^22.22.2"
  },
  "scripts": {
    "audit": "audit-ci --config ./audit-ci.jsonc --skip-dev --report-type summary",
    "build-standalone": "node build-standalone",
    "build-storybook": "storybook build",
    "build": "next build --webpack",
    "debug": "cross-env NODE_OPTIONS='--inspect' next dev --webpack",
    "dev": "next dev --webpack",
    "build-and-run": "npm run build && npm run start",
    "fix": "concurrently -c auto \"npm run *:fix\"",
    "eslint": "eslint . --color",
    "eslint:fix": "npm run eslint -- --fix",
    "lint": "concurrently -c auto --kill-others-on-fail \"npm:eslint\" \"npm:prettier\" \"npm:stylelint\" \"npm:type-check\"",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production'){process.exit(1)} \" || husky",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "start": "cross-env NODE_ENV=production node server.js",
    "startNext": "node_modules/next/dist/bin/next start",
    "storybook": "storybook dev -p 6006",
    "stylelint": "stylelint \"**/*.{css,scss}\" --max-warnings=0 --color",
    "stylelint:fix": "npm run stylelint -- --fix",
    "test:storybook": "vitest run --project=storybook",
    "test:unit": "vitest run --project=unit",
    "test:ci": "vitest run --project=unit --coverage",
    "test:coverage": "vitest run --coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --pretty --noEmit",
    "generate": "plop --plopfile src/tools/plopfile.js",
    "generate:credentials": "node src/tools/auth/generateHashedCredentials",
    "generate:ecommerce-api": "node src/tools/generate-ecommerce-api-schema.mjs"
  },
  "sideEffects": false,
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "classnames": "^2.5.1",
    "dc-delivery-sdk-js": "^1.4.0",
    "dc-extensions-sdk": "^2.5.0",
    "dc-management-sdk-js": "^3.3.0",
    "dc-visualization-sdk": "^1.1.0",
    "embla-carousel-react": "^8.2.1",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "lodash": "^4.17.23",
    "markdown-to-jsx": "^7.7.17",
    "motion": "^12.23.24",
    "next": "16.2.6",
    "next-localization": "^0.12.0",
    "openapi-fetch": "^0.13.0",
    "openapi-react-query": "^0.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.65.0",
    "remove-markdown": "^0.6.2",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "vwo-smartcode-nextjs": "^1.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/nextjs-vite": "10.3.6",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/eslint-plugin-query": "^5.91.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.18.10",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "audit-ci": "^7.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "css-loader": "^6.11.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.3.6",
    "eslint-plugin-testing-library": "^7.13.2",
    "eslint-plugin-typescript-sort-keys": "^3.3.0",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.4",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.59.1",
    "plop": "^4.0.5",
    "prettier": "^3.6.2",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.93.2",
    "sass-loader": "^16.0.7",
    "storybook": "^10.3.6",
    "storybook-addon-pseudo-states": "^10.3.6",
    "style-loader": "^4.0.0",
    "stylelint": "^16.25.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "util": "^0.12.5",
    "validate-branch-name": "^1.3.0",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "webpack": "5"
  },
  "validate-branch-name": {
    "pattern": "^(main|develop){1}$|^(bugfix|feature|hotfix)/((ECOMDEV)-[0-9]{1,5}-[a-z0-9-]{3,60})$|^release/[0-9]+[.][0-9]+[.][0-9]+$",
    "errorMsg": "Invalid branch name, make sure branch name structure is correct: [bugfix|feature|hotfix]/[user-story-id]-[branch-name] e.g. feature/12345-add-new-feature"
  },
  "overrides": {
    "axios": "^1.16.0",
    "follow-redirects": "^1.16.0",
    "postcss": "^8.5.10",
    "underscore": "^1.13.8",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
