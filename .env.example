# NextJS
NEXT_PUBLIC_DOMAIN_NAME=http://localhost:3000
REVALIDATE_TIME=600

# Features - Theming
NEXT_PUBLIC_THEME_NAME=giant

# Features - language versions
NEXT_PUBLIC_AVAILABLE_COUNTRIES=string
NEXT_PUBLIC_ALLOWED_LOCALES=string
ACCESS_RESTRICTED_LOCALE_USERNAME_HASH=string
ACCESS_RESTRICTED_LOCALE_PASSWORD_HASH=string

# Services - Tracking
NEXT_PUBLIC_GOOGLE_ANALYTICS=string
NEXT_PUBLIC_VWO_ACCOUNT_ID=string
NEXT_PUBLIC_VWO_SETTINGS_TOLERANCE=string

# Amplience
NEXT_PUBLIC_AMPLIENCE_MAIN_SITE_URL=string
NEXT_PUBLIC_AMPLIENCE_BASE_PATH=string
NEXT_PUBLIC_AMPLIENCE_HUB_ID=string
NEXT_PUBLIC_AMPLIENCE_STAGING_ENV=string
NEXT_PUBLIC_AMPLIENCE_VISUALISATION_DOMAIN=string

# Amplience management API
AMPLIENCE_PAT=string
AMPLIENCE_GLOBAL_REPOSITORY_ID=string
AMPLIENCE_NEXT_API_ROUTE_KEY=string
NEXT_PUBLIC_AMPLIENCE_GLOBAL_LOCALE=string
ACCESS_AMPLIENCE_SECRET_KEY_AMPLIENCE=string
ACCESS_AMPLIENCE_SECRET_KEY_INTERNAL=string
ACCESS_AMPLIENCE_CONFIG_DELIVERY_KEY=string

# Klaviyo
KLAVIYO_API_KEY=string
KLAVIYO_NEWSLETTER_LIST_ID=string

# Giant E-commerce API
ECOMMERCE_OCP_APIM_SUBSCRIPTION_KEY=string
ECOMMERCE_API_URL=https://ghq-api-t-azwe-api-1.azure-api.net/ecommerce/v1

# OpenAPI spec for `npm run generate:ecommerce-api` (SAS = query string after ? from the blob URL)
ECOMMERCE_OPENAPI_SPEC_BASE_URL=https://ghqapitazwesta1.blob.core.windows.net/openapi/ecommerce-v1.json
ECOMMERCE_OPENAPI_SPEC_SAS=string
